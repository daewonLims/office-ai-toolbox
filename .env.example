# 사용할 프로바이더의 키만 설정하면 됩니다. (Claude / GPT / Gemini 중 원하는 것만)
# 실제 키는 .env.local에 넣으세요. .env.local은 절대 커밋되지 않습니다.

# Anthropic Claude — https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=

# OpenAI GPT — https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=

# (선택) 모델 이름 재정의 — 미설정 시 코드의 기본값을 사용합니다.
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-5.6
# GEMINI_MODEL=gemini-3.5-flash
